PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (get this from your Atlas cluster -> Connect -> Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ecommerce?retryWrites=true&w=majority

# JWT secrets - use long random strings in production (e.g. output of: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL, used for CORS
CLIENT_URL=http://localhost:5173
